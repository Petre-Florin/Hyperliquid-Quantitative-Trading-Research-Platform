# Copy to .env and fill in. Never commit .env.
# Populated properly starting Phase 8 (config.py via pydantic-settings).

# --- Mode ---
TRADING_MODE=paper          # paper | live

# --- Hyperliquid (Phase 9) ---
# Use a scoped API wallet key, NOT your main wallet's private key.
HYPERLIQUID_API_WALLET_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=

# --- Risk limits (Phase 5) ---
MAX_EXPOSURE_PCT=0.20
MAX_POSITION_PCT_PER_SYMBOL=0.05
MIN_SIGNAL_CONFIDENCE=0.6
LEVERAGE=5.0

# --- Fees ---
TRADE_DOLLAR_AMOUNT=100.0
TAKER_FEE_PCT=0.00045
MAKER_FEE_PCT=0.00015



